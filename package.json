  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- vp dev --port 3000",
    "build": "vp build && cp instrument.server.mjs .output/server",
    "preview": "vp preview",
    "test": "vp test run",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:export": "drizzle-kit export",
    "check": "vp check --no-fmt",
    "lint": "vp lint",
    "check:changed": "git diff --cached --name-only --diff-filter=d | xargs bun vp check --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-storybook:test": "storybook build --test --stats-json",
    "chromatic": "bun run build-storybook:test && chromatic --storybook-build-dir storybook-static",
    "prepare": "vp config",
    "commit": "cz",
    "railway:dev": "railway run -- sh -c \"BETTER_AUTH_URL=http://localhost:3000 vp dev --port 3000\"",
    "railway:build": "railway run -- vp build && cp instrument.server.mjs .output/server",
    "railway:start": "railway run -- node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "railway:db:generate": "railway run -- drizzle-kit generate",
    "railway:db:migrate": "railway run -- drizzle-kit migrate",
    "railway:db:push": "railway run -- drizzle-kit push",
    "railway:db:studio": "railway run -- drizzle-kit studio",
    "railway:atlas:diff": "railway run -- bash scripts/atlas-diff.sh",
    "railway:atlas:push": "railway run -- atlas migrate push brackeys --env local",
    "railway:atlas:apply": "railway run -- atlas migrate apply --env prod",
    "atlas:diff": "bash scripts/atlas-diff.sh",
    "atlas:apply": "atlas migrate apply --env local",
    "atlas:status": "atlas migrate status --env local",
    "atlas:push": "atlas migrate push brackeys --env local"
  },
