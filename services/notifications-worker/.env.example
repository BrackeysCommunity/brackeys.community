# Postgres connection string — the same DB the main brackeys app uses.
DATABASE_URL=postgres://user:pass@host:5432/brackeys

# Redis connection string — the same Redis the web app uses to enqueue jobs.
# On Railway this will usually be a private network URL:
#   REDIS_URL=redis://default:password@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379

# Concurrency for each Worker. Bump if side-effects start backing up.
NOTIFICATIONS_CONCURRENCY=5
EMAIL_CONCURRENCY=10
