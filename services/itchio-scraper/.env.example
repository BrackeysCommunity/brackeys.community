# Postgres connection string — the same DB the main brackeys app uses.
DATABASE_URL=postgres://user:pass@host:5432/brackeys

# Browserless v2 websocket endpoint. Point this at your Browserless service.
# On Railway this will usually be a private network URL:
#   BROWSERLESS_WS_ENDPOINT=wss://browserless.railway.internal?token=your-token
BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io?token=REPLACE_ME

# When to scrape the per-entry rate page (which carries per-criterion ranks).
#   always        — every run
#   after-voting  — only when jam.status === "over" (default)
#   never         — skip entirely
SCRAPE_ENTRY_RESULTS=after-voting

# Throttling for rate-page scrape.
ENTRY_RESULTS_CONCURRENCY=3
ENTRY_RESULTS_DELAY_MS=500

USER_AGENT=brackeys-itchio-scraper/0.1 (+https://brackeys.community)
